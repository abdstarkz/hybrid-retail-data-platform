# ============================================
# Hybrid Retail Analytics Platform
# Bronze to Silver Transformation
# Azure Databricks + PySpark + Delta Lake
# ============================================

from pyspark.sql.functions import *
from pyspark.sql.window import Window
from delta.tables import DeltaTable

# --------------------------------------------
# Storage Paths
# --------------------------------------------

bronze_sales_path = "abfss://bronze@retailstorage.dfs.core.windows.net/sales/"
silver_sales_path = "abfss://silver@retailstorage.dfs.core.windows.net/sales_cleaned/"
gold_kpi_path = "abfss://gold@retailstorage.dfs.core.windows.net/sales_kpis/"

# --------------------------------------------
# Read Raw CSV Sales Data
# --------------------------------------------

raw_sales_df = spark.read \
    .format("csv") \
    .option("header", "true") \
    .option("inferSchema", "true") \
    .load(bronze_sales_path)

# --------------------------------------------
# Initial Data Validation
# --------------------------------------------

validated_df = raw_sales_df.filter(
    col("transaction_id").isNotNull()
)

# --------------------------------------------
# Remove Duplicate Transactions
# --------------------------------------------

window_spec = Window.partitionBy("transaction_id") \
    .orderBy(col("transaction_date").desc())

deduplicated_df = validated_df \
    .withColumn(
        "row_num",
        row_number().over(window_spec)
    ) \
    .filter(col("row_num") == 1) \
    .drop("row_num")

# --------------------------------------------
# Data Cleansing and Standardization
# --------------------------------------------

cleaned_sales_df = deduplicated_df \
    .withColumn(
        "customer_name",
        initcap(trim(col("customer_name")))
    ) \
    .withColumn(
        "product_category",
        upper(trim(col("product_category")))
    ) \
    .withColumn(
        "transaction_date",
        to_timestamp(col("transaction_date"))
    ) \
    .withColumn(
        "order_date",
        to_date(col("transaction_date"))
    ) \
    .withColumn(
        "sales_amount",
        round(
            col("quantity") * col("unit_price"),
            2
        )
    ) \
    .withColumn(
        "discount_amount",
        round(
            col("sales_amount") * (col("discount_percent") / 100),
            2
        )
    ) \
    .withColumn(
        "net_sales",
        round(
            col("sales_amount") - col("discount_amount"),
            2
        )
    ) \
    .withColumn(
        "profit_margin",
        round(
            (
                (col("net_sales") - col("cost_price"))
                / col("net_sales")
            ) * 100,
            2
        )
    ) \
    .withColumn(
        "ingestion_timestamp",
        current_timestamp()
    )

# --------------------------------------------
# Handle Null Values
# --------------------------------------------

final_sales_df = cleaned_sales_df.fillna({
    "customer_name": "Unknown Customer",
    "region": "Undefined",
    "discount_percent": 0
})

# --------------------------------------------
# Write Silver Layer Delta Table
# --------------------------------------------

final_sales_df.write \
    .format("delta") \
    .mode("overwrite") \
    .partitionBy("order_date") \
    .save(silver_sales_path)

print("Silver layer transformation completed successfully")

# ============================================
# Gold Layer KPI Processing
# ============================================

silver_df = spark.read \
    .format("delta") \
    .load(silver_sales_path)

# --------------------------------------------
# Regional Sales KPIs
# --------------------------------------------

regional_sales_kpi = silver_df.groupBy(
    "region"
).agg(
    round(sum("net_sales"), 2).alias("total_revenue"),
    countDistinct("customer_id").alias("total_customers"),
    countDistinct("transaction_id").alias("total_orders"),
    round(avg("net_sales"), 2).alias("average_order_value"),
    round(avg("profit_margin"), 2).alias("avg_profit_margin")
)

# --------------------------------------------
# Product Performance Analytics
# --------------------------------------------

product_analytics = silver_df.groupBy(
    "product_category"
).agg(
    round(sum("net_sales"), 2).alias("category_revenue"),
    sum("quantity").alias("units_sold"),
    round(avg("profit_margin"), 2).alias("avg_margin")
).orderBy(
    desc("category_revenue")
)

# --------------------------------------------
# Monthly Revenue Trend
# --------------------------------------------

monthly_trend_df = silver_df \
    .withColumn(
        "sales_month",
        date_format(col("order_date"), "yyyy-MM")
    ) \
    .groupBy("sales_month") \
    .agg(
        round(sum("net_sales"), 2).alias("monthly_revenue")
    ) \
    .orderBy("sales_month")

# --------------------------------------------
# Customer Segmentation
# --------------------------------------------

customer_segment_df = silver_df.groupBy(
    "customer_id",
    "customer_name"
).agg(
    round(sum("net_sales"), 2).alias("lifetime_value"),
    countDistinct("transaction_id").alias("purchase_frequency")
).withColumn(
    "customer_segment",
    when(col("lifetime_value") >= 50000, "Premium")
    .when(col("lifetime_value") >= 20000, "Gold")
    .when(col("lifetime_value") >= 10000, "Silver")
    .otherwise("Standard")
)

# --------------------------------------------
# Save Gold Layer Tables
# --------------------------------------------

regional_sales_kpi.write \
    .format("delta") \
    .mode("overwrite") \
    .save(f"{gold_kpi_path}/regional_sales")

product_analytics.write \
    .format("delta") \
    .mode("overwrite") \
    .save(f"{gold_kpi_path}/product_analytics")

monthly_trend_df.write \
    .format("delta") \
    .mode("overwrite") \
    .save(f"{gold_kpi_path}/monthly_trends")

customer_segment_df.write \
    .format("delta") \
    .mode("overwrite") \
    .save(f"{gold_kpi_path}/customer_segments")

print("Gold layer KPI generation completed successfully")

# ============================================
# Delta Lake Optimization
# ============================================

spark.sql(f"""
OPTIMIZE delta.`{gold_kpi_path}/regional_sales`
ZORDER BY (region)
""")

spark.sql(f"""
OPTIMIZE delta.`{gold_kpi_path}/product_analytics`
ZORDER BY (product_category)
""")

spark.sql(f"""
VACUUM delta.`{gold_kpi_path}/regional_sales`
RETAIN 168 HOURS
""")

print("Delta Lake optimization completed")

# ============================================
# Data Quality Validation
# ============================================

validation_results = {
    "total_records": final_sales_df.count(),
    "duplicate_transactions": (
        final_sales_df.count()
        - final_sales_df.select("transaction_id").distinct().count()
    ),
    "null_customer_names": final_sales_df.filter(
        col("customer_name").isNull()
    ).count(),
    "total_revenue": final_sales_df.agg(
        round(sum("net_sales"), 2)
    ).collect()[0][0]
}

print("Data Validation Summary")
print(validation_results)